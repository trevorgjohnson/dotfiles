#!/bin/bash

# Opens a diff between the current working state and a base branch in $EDITOR for inline annotation.
# Annotations use the ">> " prefix which never appears in unified diff output.
# Produces an annotated diff file ready to paste into Claude for automated change implementation.

set -euo pipefail

PRUNE=false

# Parse flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--prune) PRUNE=true; shift ;;
    -h|--help) BASE_BRANCH="--help"; shift ;;
    *) BASE_BRANCH="$1"; shift ;;
  esac
done

BASE_BRANCH="${BASE_BRANCH:-}"

# Show usage on missing arg or help flag
if [[ -z "$BASE_BRANCH" || "$BASE_BRANCH" == "--help" ]]; then
  echo "Usage: git-review [options] <base-branch>

Generates a diff between the current working state (committed + staged + unstaged)
and the given base branch, opens it in \$EDITOR for inline annotation, and saves
the annotated result.

Options:
  -p, --prune    Remove all previous review files saved under .git/
  -h, --help     Show this help message

Add annotations anywhere in the diff with the \">> \" prefix:
  >> your change request here

Examples:
  git-review main
  git-review develop
  git-review --prune develop
"
  exit 1
fi

# Must be inside a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "Error: not inside a git repository."
  exit 1
fi

# Base branch must exist
if ! git rev-parse --verify "$BASE_BRANCH" &>/dev/null; then
  echo "Error: branch '$BASE_BRANCH' does not exist."
  exit 1
fi

GIT_DIR=$(git rev-parse --show-toplevel)/.git

# Prune previous reviews if requested
if [[ "$PRUNE" == true ]]; then
  REVIEW_FILES=("$GIT_DIR"/review-*.diff)
  if [[ -e "${REVIEW_FILES[0]}" ]]; then
    rm -f "$GIT_DIR"/review-*.diff
    echo "Pruned ${#REVIEW_FILES[@]} previous review file(s)."
  else
    echo "No previous review files to prune."
  fi
fi

DIFF=$(git diff --no-color "$BASE_BRANCH")

if [[ -z "$DIFF" ]]; then
  echo "No differences between '$BASE_BRANCH' and the current working state."
  exit 0
fi

CURRENT_BRANCH=$(git branch --show-current)
# Detached HEAD won't have a branch name
CURRENT_BRANCH=${CURRENT_BRANCH:-"(detached HEAD)"}

TMPFILE=$(mktemp /tmp/git-review-XXXXXX.diff)

# Build the review file: header + diff
cat > "$TMPFILE" <<EOF
# ==============================
# DIFF REVIEW: $CURRENT_BRANCH vs $BASE_BRANCH
# Includes uncommitted staged/unstaged changes
# ==============================
#
# Add annotations with ">> " on any line:
#   >> your change request here
#
# Save and exit when done.
# ==============================

$DIFF
EOF

# Pick an editor — respect $EDITOR, fall back to nvim then vi
REVIEW_EDITOR="${EDITOR:-nvim}"
if ! command -v "$REVIEW_EDITOR" &>/dev/null; then
  REVIEW_EDITOR="vi"
fi

"$REVIEW_EDITOR" "$TMPFILE"

# Check if the user added any annotations
if grep -q '^>> ' "$TMPFILE"; then
  # Truncate to LLM-friendly output: new header + only hunks containing ">> " annotations.
  # Walks the diff structure (file header -> hunk), buffers each piece, and only emits
  # a hunk (plus its parent file header) when the hunk contains an annotation.
  awk '
    # Emits the buffered hunk (and its parent file header, once) if the hunk
    # was marked as annotated. Called at every file/hunk boundary and at EOF.
    function flush() {
      if (hunk_annotated) {
        if (!file_printed) { printf "%s", file_header; file_printed = 1 }
        printf "%s", hunk
      }
    }
    /^(#|$)/ && !past_header { next }                                            # skip original comment header
    !past_header { past_header = 1 }                                             # first non-header line; begin diff parsing
    /^diff --git / { flush(); file_header=$0"\n"; file_printed=0; hunk=""; hunk_annotated=0; next }
    !hunk && !/^@@ / { file_header=file_header $0"\n"; next }                    # buffer file header lines (index/---/+++)
    /^@@ /            { flush(); hunk=$0"\n"; hunk_annotated=0; next }
    /^>> /             { hunk_annotated=1 }                                      # mark hunk as annotated
    hunk               { hunk=hunk $0"\n"; next }                                # buffer hunk lines
    END                { flush() }
  ' "$TMPFILE" > "${TMPFILE}.truncated" && mv "${TMPFILE}.truncated" "$TMPFILE"

  # Prepend LLM-facing instructions
  HEADER="# Code review — annotated change requests
# Each \">> \" line is a change request within its surrounding diff hunk.
# Implement all requested changes.
"
  printf '%s\n%s' "$HEADER" "$(cat "${TMPFILE}")" > "$TMPFILE"
  TIMESTAMP=$(date +%Y%m%d-%H%M%S)
  # Sanitize branch name for filename (replace / with -)
  SAFE_BRANCH=$(echo "$BASE_BRANCH" | tr '/' '-')
  OUTPUT_FILE="${GIT_DIR}/review-${SAFE_BRANCH}-${TIMESTAMP}.diff"

  mv "$TMPFILE" "$OUTPUT_FILE"

  echo "Review saved to: $OUTPUT_FILE"

  # Offer clipboard copy (macOS pbcopy or Linux Wayland wl-copy)
  CLIP_CMD=""
  if command -v pbcopy &>/dev/null; then
    CLIP_CMD="pbcopy"
  elif command -v wl-copy &>/dev/null; then
    CLIP_CMD="wl-copy"
  fi
  if [[ -n "$CLIP_CMD" ]]; then
    read -p "Copy to clipboard? [Y/n] " -n 1 -r COPY_ANSWER
    echo ""
    if [[ ! "$COPY_ANSWER" =~ ^[Nn]$ ]]; then
      "$CLIP_CMD" < "$OUTPUT_FILE"
      echo "Copied to clipboard."
    fi
  fi
else
  rm -f "$TMPFILE"
  echo "No annotations found — review discarded."
fi
