#!/bin/sh

menu() {
  local prompt="$1"
  local options="$2"
  echo -e "$options" | rofi -dmenu -i -p "$prompt‚Ä¶" "${args[@]}" 2>/dev/null
}

open_in_term() {
  $TERMINAL -e "$1"
}

open_in_editor() {
  notify-send "Editing config file" "$1"
  $TERMINAL -e $EDITOR "$1"
}

launch_wifi() {
    rfkill unblock wifi
    $TERMINAL -e impala
}

launch_bluetooth() {
    rfkill unblock bluetooth
    $TERMINAL -e bluetui
}

go_to_menu() {
  case "${1,,}" in
  *apps*) rofi -show combi -p "Go..." ;;
  *terminal*) $TERMINAL ;;
  *keybinds*) keybindings | rofi -dmenu ;;
  *emoji*) dmoji ;;
  *screenshot*) /home/trevo/bin/screenshot ;;
  *wallpaper*) open_in_term /home/trevo/bin/select-wallpaper ;;
  *config*) open_in_term /home/trevo/bin/edit-config ;;
  *audio*) open_in_term wiremix ;;
  *wifi*) launch_wifi ;;
  *bluetooth*) launch_bluetooth ;;
  *vpn*) open_in_term /home/trevo/bin/toggle-vpn ;;
  *power*) open_in_term /home/trevo/bin/select-tlp-profile ;;
  *suspend*) systemctl suspend ;;
  *restart*) systemctl reboot --no-wall ;;
  *shutdown*) systemctl poweroff --no-wall ;;
  esac
}

# current list of items:
# ůįÄĽ   Apps
# Óěē   Terminal
# ÔĄú   Keybinds
# ůįěÖ   Emoji
# ÔÄį   Screenshot
# ůįłČ   Wallpaper
# Óėē   Config
# Óėł   Audio
# Ôáę   Wifi
# ůįāĮ   Bluetooth
# ůįī≥   VPN
# ůĪźč   Power Profile
# ůį§Ą   Suspend
# ůįúČ   Restart
# ůįź•   Shutdown
go_to_menu "$(menu "Go" "ůįÄĽ   Apps\nÓěē   Terminal\nÔĄú   Keybinds\nůįěÖ   Emoji\nÔÄį   Screenshot\nůįłČ   Wallpaper\nÓėē   Config\nÓėł   Audio\nÔáę   Wifi\nůįāĮ   Bluetooth\nůįī≥   VPN\nůĪźč   Power Profile\nůį§Ą   Suspend\nůįúČ   Restart\nůįź•   Shutdown")"
