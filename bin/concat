#!/bin/bash

# This script concatenates and lowers the quality (by default) of a list of input clips

# Get input params
CLIP_LOC=$1
OUTPUT_NAME=$2
FFMPEG_OPTS=$3

# Set in strict mode
set -euo pipefail

# Exit if input list is empty or nonexistent
if [[ -z $CLIP_LOC || ! -d $CLIP_LOC || "$1" == "-h" || "$1" == "--help" ]]; then
  echo "Usage: concat <clip_loc> <output.mp4> <ffmpeg_opts>

clip_loc    - This is the directory where all of the clips are in.
              Note that the clips will be concattenated in the order that they are within the folder.

output.mp4  - This is the name of the concatenated video. This will default to \`output.mp4\` if not specified.

ffmpeg_opts - Specific ffmpeg options used to control the quality of the finalized.
              This will default to H264 with a CRF of 30 - this should be great for an clip montage
              Some other useful options might be:
              - \"-c copy\" - Essentially skips encoding (which is super fast with no quality/size changes)
"
  exit 1
fi

# If output is not given, default to `output.mp4`
if [[ -z $OUTPUT_NAME ]] then
  OUTPUT_NAME="output.mp4"
fi

# If no specific ffmpeg opts are given, default to some sensible clipping settings
if [[ -z $FFMPEG_OPTS ]] then
  FFMPEG_OPTS="-vcodec libx264 -threads 0 -crf 30"
fi

# If the output file already exists, append "new" until we find a free path.
if [[ -e "$OUTPUT_NAME" ]]; then
  output_dir=$(dirname -- "$OUTPUT_NAME")
  output_file=$(basename -- "$OUTPUT_NAME")
  output_stem=${output_file%.*}
  output_ext=

  if [[ $output_file == *.* && $output_file != .* ]]; then
    output_ext=.${output_file##*.}
  fi

  output_candidate="$output_stem"
  while [[ -e "$output_dir/$output_candidate$output_ext" ]]; do
    output_candidate="${output_candidate}new"
  done

  OUTPUT_NAME="$output_dir/$output_candidate$output_ext"
fi

# Get a list of all of the images to upscale
CLIPS=$(ls $CLIP_LOC)

# Concat all of the clips under the input clip location
ffmpeg -f concat -safe 0 -i <(for f in $CLIPS; do echo "file '$CLIP_LOC/$f'"; done) $FFMPEG_OPTS "$OUTPUT_NAME"
echo "Saved to $OUTPUT_NAME"
